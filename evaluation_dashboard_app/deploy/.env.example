# Production deployment: copy to .env and set values.
# Used by docker-compose and optionally by Streamlit/worker at runtime.

# Data root for evaluation runs (must be a path visible inside containers)
EVAL_DASHBOARD_DATA_ROOT=/app/data

# Task queue: set to true to use Redis + Worker + Postgres
USE_TASK_QUEUE=true

# Postgres (task metadata). Match POSTGRES_* for the postgres service.
POSTGRES_USER=eval_user
POSTGRES_PASSWORD=eval_pass
POSTGRES_DB=eval_dashboard
DATABASE_URL=postgresql://eval_user:eval_pass@postgres:5432/eval_dashboard

# Redis (task queue)
REDIS_URL=redis://redis:6379/0
RQ_QUEUE=default

# RQ: max job runtime before the worker kills the job (seconds). Default 7 days if unset.
# RQ_JOB_TIMEOUT_SEC=604800
# Optional: longer timeout for build_parquet only (defaults to RQ_JOB_TIMEOUT_SEC if unset)
# RQ_BUILD_PARQUET_TIMEOUT_SEC=604800

# Optional: per-user task visibility (company auth / WebAutoAuth)
# Header name set by auth proxy with current user id (e.g. X-Forwarded-User)
# AUTH_USER_HEADER=X-Forwarded-User
# Dev fallback when no proxy: AUTH_DEFAULT_USER=dev@example.com

# Optional: Nginx only exposes 80; set for TLS in production
# NGINX_HTTPS=1

# Optional: filter containers on Deployment debug page (see PRODUCTION_DEPLOYMENT.md)
# EVAL_DEPLOYMENT_DEBUG_COMPOSE_PROJECT=myproject
# Optional: allow "Run command" (docker exec) on that page — high risk; default 0 in compose
# EVAL_DEPLOYMENT_DEBUG_EXEC=1
